# Wajib diisi
RPC_URL=https://ethereum-rpc.publicnode.com
PRIVATE_KEY=0xPRIVATE_KEY_KAMU

# Backend: auto | cpu | opencl
MINER_BACKEND=opencl

# GPU batch size - lebih besar = lebih cepat (default 256M, turunkan jika OOM)
GPU_BATCH_SIZE=268435456

# Priority fee gas (gwei)
PRIORITY_FEE_GWEI=2

# CPU fallback workers (default: semua core - 1)
# CPU_WORKERS=8

# Terus mining setelah mint (default: true)
KEEP_MINING=true
